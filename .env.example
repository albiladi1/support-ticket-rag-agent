# Copy this file to .env and fill in your values

# OpenRouter (free LLM gateway) - https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=support_tickets_raw
KAFKA_TOPIC_DLQ=support_tickets_dlq

# Delta Lakehouse paths (local for dev; swap for S3/ADLS in prod)
LAKEHOUSE_ROOT=./lakehouse
BRONZE_PATH=./lakehouse/bronze/tickets
SILVER_PATH=./lakehouse/silver/tickets
GOLD_PATH=./lakehouse/gold/tickets

# Vector index
VECTOR_INDEX_PATH=./lakehouse/gold/vector_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenLineage
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=support-ticket-rag-agent